---
import BottomWave from "../components/layouts/BottomWave.astro";
import Wave from "../components/layouts/Wave.astro";
import Switch from "../components/ui/Switch.astro";
import "../styles/global.css";
---

<html lang="es">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Doto:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <meta charset="UTF-8" />

    <script is:inline>
      (function () {
        const root = document.documentElement;
        const saved = localStorage.getItem("theme");

        if (saved === "dark" || saved === "light") {
          root.classList.toggle("dark", saved === "dark");
        } else {
          const prefersDark = window.matchMedia(
            "(prefers-color-scheme: dark)",
          ).matches;
          root.classList.toggle("dark", prefersDark);
        }
      })();
    </script>
    <title>Alejandro Ismael Chañi - Portfolio</title></head
  >
</html>

<body class="bg-base text-text-primary relative scroll-smooth font-sans">
  <main class="mx-auto flex max-w-5xl flex-col gap-28 px-12 py-32">
    <Wave />
    <Switch />
    <slot />
    <BottomWave />
  </main>
</body>
