---
import ExperienceCard from "../experience/ExperienceCard.astro";
import DisplayScramble from "../ui/DisplayScramble.astro";
import { DEFAULT_LOCALE, getDictionary } from "../../i18n";

const dictionary = getDictionary(DEFAULT_LOCALE);
const experiences = dictionary.experience.items;
---

<section id="experience" class="flex flex-col gap-6 sm:gap-8">
  <!-- TITLE -->
  <DisplayScramble
    as="h1"
    text={dictionary.experience.title}
    i18nKey="experience.title"
    class="text-2xl tracking-wide md:text-3xl"
    delay={300}
    duration={800}
    scrambleStepMs={40}
    initialCharCount={30}
    scrambleChars="X"
  />

  <!-- CARDS -->
  <div class="flex flex-col gap-6 md:gap-8">
    {
      experiences.map((exp, index) => (
        <ExperienceCard {...exp} i18nKeyPrefix={`experience.items.${index}`} />
      ))
    }
  </div>
</section>

<script>
  import { applyFadeInEffect } from "../../utils/fadeInEffect";

  applyFadeInEffect(".experience-card");
</script>
