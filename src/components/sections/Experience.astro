---
import ExperienceCard from "../experience/ExperienceCard.astro";
import DisplayScramble from "../ui/DisplayScramble.astro";
import { DEFAULT_LOCALE, getDictionary } from "../../i18n";
import { EXPERIENCE_ORDER, experienceStructure } from "../../data/experiences";
import { technologyCatalog } from "../../data/technologies";

const dictionary = getDictionary(DEFAULT_LOCALE);
const experiences = EXPERIENCE_ORDER.map((experienceId) => {
  const structure = experienceStructure[experienceId];
  const copy = dictionary.experience.itemsById[experienceId];
  const techs = structure.techIds?.map((techId) => {
    const technology = technologyCatalog[techId];
    return { label: technology.label, icon: technology.icon };
  });

  return {
    ...structure,
    ...copy,
    techs,
  };
});
---

<section id="experience" class="flex flex-col gap-6 sm:gap-8">
  <!-- TITLE -->
  <DisplayScramble
    as="h1"
    text={dictionary.experience.title}
    i18nKey="experience.title"
    class="text-2xl tracking-wide md:text-3xl"
    delay={300}
    duration={800}
    scrambleStepMs={40}
    initialCharCount={30}
    scrambleChars="X"
  />

  <!-- CARDS -->
  <div class="flex flex-col gap-6 md:gap-8">
    {
      experiences.map((exp) => (
        <ExperienceCard {...exp} i18nKeyPrefix={`experience.itemsById.${exp.id}`} />
      ))
    }
  </div>
</section>

<script>
  import { applyFadeInEffect } from "../../utils/fadeInEffect";

  applyFadeInEffect(".experience-card");
</script>
