---
import SideBarItem from "../ui/SideBarItem.astro";
import Icon from "../ui/Icon.astro";

const items = [
  { id: "intro", icon: "home", label: "Introducción" },
  // { id: "assistant", icon: "ai", label: "Asistente virtual" },
  { id: "experience", icon: "experience", label: "Experiencia y Educación" },
  { id: "technologies", icon: "technologies", label: "Tecnologías" },
  { id: "contact", icon: "contact", label: "Contacto" },
];
---

<!-- DESKTOP SIDEBAR -->
<aside
  id="sidebar"
  class="group bg-surface shadow-neumorphic pointer-events-none fixed top-1/2 left-6 z-50 hidden w-fit max-w-20 -translate-x-2 -translate-y-1/2 flex-col items-stretch gap-2 overflow-hidden rounded-3xl p-2 opacity-0 transition-[opacity,transform,max-width] duration-600 ease-in-out hover:max-w-[24rem] md:flex"
  style="visibility: hidden;"
>
  <div
    id="sidebar-indicator"
    class="bg-surface shadow-neumorphic-inset pointer-events-none absolute right-2 left-2 z-0 rounded-full transition-[top,height,left,width] duration-400 ease-linear"
    style="top: 0px;"
  >
  </div>

  {
    items.map((item) => {
      return <SideBarItem icon={item.icon} label={item.label} id={item.id} />;
    })
  }
</aside>

<!-- MOBILE PILL NAV -->
<nav
  id="mobile-nav"
  class="bg-surface shadow-neumorphic pointer-events-none fixed bottom-[1dvh] left-1/2 z-50 flex -translate-x-1/2 translate-y-2 items-center gap-1 rounded-full p-2 opacity-0 transition-[opacity,transform] duration-600 ease-in-out md:hidden"
>
  <div
    id="mobile-indicator"
    class="bg-surface shadow-neumorphic-inset pointer-events-none absolute top-2 bottom-2 z-0 rounded-full transition-all duration-300 ease-in-out"
    style="left: 0px; width: 0px;"
  >
  </div>

  {
    items.map((item) => (
      <div
        data-id={item.id}
        class="mobile-nav-item text-text-secondary relative z-10 flex cursor-pointer items-center justify-center rounded-full p-3"
      >
        <Icon
          icon={item.icon}
          class="h-5 w-5 shrink-0"
          changeColorOnHover={false}
        />
      </div>
    ))
  }
</nav>

<script>
  import { initializeSidebarNavigation } from "../../utils/sidebarClient";

  window.addEventListener("DOMContentLoaded", initializeSidebarNavigation);
</script>
