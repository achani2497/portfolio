---
import SideBarItem from "../ui/SideBarItem.astro";

const items = [
  { id: "intro", icon: "home", label: "Introducción" },
  // { id: "assistant", icon: "ai", label: "Asistente virtual" },
  { id: "experience", icon: "experience", label: "Experiencia y Educación" },
  { id: "technologies", icon: "technologies", label: "Tecnologías" },
  { id: "contact", icon: "contact", label: "Contacto" },
];
---

<aside
  id="sidebar"
  class="group bg-surface shadow-neumorphic pointer-events-none fixed top-1/2 left-6 z-50 flex w-fit max-w-20 -translate-x-2 -translate-y-1/2 flex-col items-stretch gap-2 overflow-hidden rounded-3xl p-2 opacity-0 transition-[opacity,transform,max-width] duration-600 ease-in-out hover:max-w-[24rem]"
  style="visibility: hidden;"
>
  <!-- INDICADOR -->
  <div
    id="sidebar-indicator"
    class="bg-surface shadow-neumorphic-inset pointer-events-none absolute right-2 left-2 z-0 rounded-full transition-all duration-300 ease-in-out"
    style="top: 0px;"
  >
  </div>

  {
    items.map((item) => {
      return <SideBarItem icon={item.icon} label={item.label} id={item.id} />;
    })
  }
</aside>

<script is:inline>
  window.addEventListener("DOMContentLoaded", () => {
    const sidebar = document.querySelector("#sidebar");
    const items = document.querySelectorAll(".sidebar-item");
    const indicator = document.getElementById("sidebar-indicator");

    // animación inicial de aparición del sidebar
    if (sidebar) {
      setTimeout(() => {
        sidebar.classList.remove(
          "opacity-0",
          "-translate-x-2",
          "pointer-events-none",
        );

        sidebar.style.visibility = "visible";
      }, 400);
    }

    function moveIndicator(index) {
      const item = items[index];
      if (!item || !indicator) return;

      indicator.style.top = `${item.offsetTop}px`;
      indicator.style.height = `${item.offsetHeight}px`;

      activeIndex = index;
    }

    // click
    items.forEach((item, index) => {
      item.addEventListener("click", () => {
        const id = item.getAttribute("data-id");
        const section = document.getElementById(id);

        if (section) {
          const y = section.getBoundingClientRect().top + window.scrollY;
          smoothScrollTo(y - 20, 650);
        }

        moveIndicator(index);
      });
    });

    // scroll tracking
    const sections = Array.from(items).map((item) =>
      document.getElementById(item.getAttribute("data-id")),
    );

    // observer para mover el indicador segun la posicion del user en el browser
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const index = sections.findIndex((sec) => sec === entry.target);
            if (index !== -1) {
              moveIndicator(index);
            }
          }
        });
      },
      {
        rootMargin: "-40% 0px -40% 0px",
      },
    );

    sections.forEach((section) => {
      if (section) observer.observe(section);
    });

    // estado inicial
    if (items.length > 0) {
      requestAnimationFrame(() => {
        moveIndicator(0);
      });
    }
  });

  function smoothScrollTo(targetY, duration = 500) {
    const startY = window.scrollY;
    const diff = targetY - startY;
    let start;

    function step(timestamp) {
      if (!start) start = timestamp;
      const time = timestamp - start;
      const percent = Math.min(time / duration, 1);

      // easing (easeInOutCubic)
      const ease =
        percent < 0.5
          ? 4 * percent * percent * percent
          : 1 - Math.pow(-2 * percent + 2, 3) / 2;

      window.scrollTo(0, startY + diff * ease);

      if (time < duration) {
        requestAnimationFrame(step);
      }
    }

    requestAnimationFrame(step);
  }
</script>
