---
import Icon from "./Icon.astro";
import ToggleSwitch from "./ToggleSwitch.astro";
---

<ToggleSwitch id="theme-toggle" thumbId="theme-thumb" ariaLabel="Theme switch">
  <Fragment slot="left">
    <Icon icon="sun" />
  </Fragment>
  <Fragment slot="right">
    <Icon icon="moon" />
  </Fragment>
</ToggleSwitch>

<script is:inline>
  const root = document.documentElement;
  const toggle = document.getElementById("theme-toggle");
  const thumb = document.getElementById("theme-thumb");
  const mdQuery = window.matchMedia("(min-width: 768px)");

  function applyTheme() {
    const isDark = root.classList.contains("dark");
    const isDesktop = mdQuery.matches;

    if (isDesktop) {
      thumb.style.transform = isDark
        ? "translateX(2.25rem)"
        : "translateX(.25rem)";
    } else {
      thumb.style.transform = isDark
        ? "translateX(2rem)"
        : "translateX(.25rem)";
    }
  }

  applyTheme();
  mdQuery.addEventListener("change", applyTheme);

  toggle?.addEventListener("click", () => {
    const nowDark = root.classList.toggle("dark");
    localStorage.setItem("theme", nowDark ? "dark" : "light");
    applyTheme();
  });
</script>
