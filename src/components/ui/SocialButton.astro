---
import Icon from "./Icon.astro";

interface Props {
  href: string;
  label: string;
  icon: string;
}

const { href, label, icon } = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="group bg-surface shadow-neumorphic hover:shadow-neumorphic-hover active:shadow-neumorphic-inset inline-flex w-full items-center justify-center gap-3 rounded-full px-6 py-3 text-center transition-all duration-200 ease-out hover:-translate-y-1 active:translate-y-0"
>
  <Icon icon={icon} />

  <span
    class="text-text-secondary group-hover:text-text-primary font-sans transition-colors duration-200"
  >
    {label}
  </span>
</a>
