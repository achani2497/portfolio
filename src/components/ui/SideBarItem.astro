---
interface Props {
  icon: any;
  label: string;
}

const { icon: Icon, label } = Astro.props;
---

<div
  class="sidebar-item flex w-full items-center py-2 px-3 rounded-full cursor-pointer text-text-secondary text-left"
>
  {/* ICONO */}
  <Icon className="w-5 h-5 shrink-0" />

  {/* LABEL */}
  <span
    class="whitespace-nowrap overflow-hidden
         max-w-0 opacity-0 p-0
         group-hover:max-w-64 group-hover:opacity-100 group-hover:pl-3
         transition-[max-width,opacity,padding-left] duration-600 ease-in-out"
  >
    {label}
  </span>
</div>
