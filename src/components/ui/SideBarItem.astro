---
import Icon from "./Icon.astro";
interface Props {
  icon: string;
  label: string;
  id: string;
}

const { icon, label, id } = Astro.props;
---

<div
  data-id={id}
  class="sidebar-item text-text-secondary relative z-10 flex w-full cursor-pointer items-center rounded-full px-3 py-2 text-left"
>
  {/* ICONO */}
  <Icon icon={icon} class="h-5 w-5 shrink-0" changeColorOnHover={false} />

  {/* LABEL */}
  <span
    class="text-text-primary max-w-0 overflow-hidden p-0 whitespace-nowrap opacity-0 transition-[max-width,opacity,padding-left] duration-600 ease-in-out group-hover:max-w-64 group-hover:pl-3 group-hover:opacity-100"
  >
    {label}
  </span>
</div>
