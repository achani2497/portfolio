---
interface Props {
  text: string;
  as?: string;
  class?: string;
  delay?: number;
  duration?: number;
  scrambleChars?: string;
  scrambleStepMs?: number;
  initialCharCount?: number;
  respectReducedMotion?: boolean;
}

const {
  text,
  as = "span",
  class: className = "",
  delay = 0,
  duration = 900,
  scrambleChars = "",
  scrambleStepMs = 90,
  initialCharCount = text.length,
  respectReducedMotion = false,
} = Astro.props as Props;

const Tag = as as any;
const charSource = (
  scrambleChars.trim().length > 0 ? scrambleChars : text
).replaceAll(" ", "");
const charPool = Array.from(charSource.length > 0 ? charSource : "X");
const getRandomChar = () =>
  charPool[Math.floor(Math.random() * charPool.length)] ?? "X";
const safeInitialCharCount = Math.max(1, Math.floor(initialCharCount));
const initialScramble = Array.from({ length: safeInitialCharCount }, () =>
  getRandomChar(),
).join("");
---

<Tag
  class={`scrambled-text font-display wrap-break-word max-w-full ${className}`.trim()}
  data-scramble
  data-text={text}
  data-delay={String(delay)}
  data-duration={String(duration)}
  data-chars={charSource}
  data-step-ms={String(scrambleStepMs)}
  data-initial-char-count={String(safeInitialCharCount)}
  data-respect-reduced-motion={String(respectReducedMotion)}
  >{initialScramble}</Tag
>

<script>
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  const runScramble = (element: Element) => {
    const finalText =
      element.getAttribute("data-text") ?? element.textContent ?? "";
    const delay = Number(element.getAttribute("data-delay") ?? 0);
    const duration = Math.max(
      200,
      Number(element.getAttribute("data-duration") ?? 900),
    );
    const scrambleStepMs = Math.max(
      16,
      Number(element.getAttribute("data-step-ms") ?? 90),
    );
    const initialCharCount = Math.max(
      1,
      Math.floor(
        Number(
          element.getAttribute("data-initial-char-count") ?? finalText.length,
        ),
      ),
    );
    const charsSource = (
      element.getAttribute("data-chars") ||
      finalText ||
      "X"
    ).replaceAll(" ", "");
    const chars = Array.from(charsSource.length > 0 ? charsSource : "X");
    const getRandomChar = () =>
      chars[Math.floor(Math.random() * chars.length)] ?? "X";
    const respectReducedMotion =
      element.getAttribute("data-respect-reduced-motion") === "true";

    if (respectReducedMotion && prefersReducedMotion) {
      element.textContent = finalText;
      return;
    }

    const getScrambledText = (length = finalText.length) => {
      let output = "";
      const safeLength = Math.max(1, Math.floor(length));
      for (let i = 0; i < safeLength; i++) output += getRandomChar();
      return output;
    };

    element.textContent = getScrambledText(initialCharCount);

    const renderFrame = (progress: number) => {
      const currentLength = Math.max(
        1,
        Math.round(
          initialCharCount + (finalText.length - initialCharCount) * progress,
        ),
      );
      const revealCount = Math.floor(
        progress * Math.min(currentLength, finalText.length),
      );
      let output = "";

      for (let index = 0; index < currentLength; index++) {
        if (index < finalText.length) {
          output += index < revealCount ? finalText[index] : getRandomChar();
        } else {
          output += getRandomChar();
        }
      }

      element.textContent = output;
    };

    const animate = () => {
      const start = performance.now();
      let lastShuffleAt = start;

      const tick = (now: number) => {
        const progress = Math.min((now - start) / duration, 1);
        if (now - lastShuffleAt >= scrambleStepMs || progress >= 1) {
          renderFrame(progress);
          lastShuffleAt = now;
        }
        if (progress < 1) {
          requestAnimationFrame(tick);
        } else {
          element.textContent = finalText;
        }
      };

      requestAnimationFrame(tick);
    };

    delay > 0 ? window.setTimeout(animate, delay) : animate();
  };

  const initObserver = () => {
    const elements = document.querySelectorAll<HTMLElement>(
      "[data-scramble]:not([data-scramble-init])",
    );

    const offset = Math.round(window.innerHeight * 0.1);

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            // ✅ marcar antes de animar para evitar doble ejecución
            entry.target.setAttribute("data-scramble-init", "true");
            runScramble(entry.target);
            observer.unobserve(entry.target);
          }
        });
      },
      { rootMargin: `0px 0px -${offset}px 0px` },
    );

    elements.forEach((el) => observer.observe(el));
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initObserver, { once: true });
  } else {
    initObserver();
  }
</script>
