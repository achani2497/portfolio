---
import Icon from "../ui/Icon.astro";

interface Props {
  label: string;
  icon: string;
}

const { label, icon } = Astro.props;
---

<div
  class="group flex items-center gap-2 px-3 py-1.5 rounded-full
  bg-surface text-text-secondary text-sm shadow-neumorphic-inset
  transition-all duration-200 ease-out hover:text-text-primary"
>
  <Icon icon={icon} />
  <span>{label}</span>
</div>
