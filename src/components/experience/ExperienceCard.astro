---
import { BookOpen, BriefcaseBusiness, GraduationCap } from "lucide-react";
import TechChip from "./TechChip.astro";

interface Tech {
  label: string;
  icon: string;
}

interface Props {
  kind?: string;
  role: string;
  company: string;
  companyInitials: string;
  period: string;
  description: string;
  logo?: string;
  techs?: Tech[];
}

const {
  kind = "work",
  role,
  company,
  companyInitials,
  period,
  description,
  logo,
  techs,
} = Astro.props;

const CornerIcon =
  kind === "work"
    ? BriefcaseBusiness
    : kind === "education"
      ? GraduationCap
      : BookOpen;
---

<div
  class="experience-card relative bg-surface rounded-4xl p-8 shadow-neumorphic flex flex-col gap-6
  opacity-0 translate-y-4 transition-all duration-400 ease-out hover:-translate-y-1"
>
  <!-- CORNER ICON -->
  <div
    class="absolute top-6 right-6 w-12 h-12 rounded-full shadow-neumorphic-inset bg-surface flex items-center justify-center text-text-secondary"
  >
    <CornerIcon className="w-5 h-5" />
  </div>

  <!-- HEADER -->
  <div class="flex flex-col sm:flex-row sm:items-start gap-4">
    <!-- LOGO -->
    <div
      class="w-14 h-14 sm:w-16 sm:h-16 rounded-xl overflow-hidden bg-elevated shadow-neumorphic flex items-center justify-center"
    >
      {
        logo ? (
          <img
            src={`/logos/${logo}`}
            loading="lazy"
            alt={company}
            class="size-full object-fill"
          />
        ) : (
          <span class="font-display text-sm tracking-wide text-text-secondary">
            {companyInitials}
          </span>
        )
      }
    </div>

    <!-- INFO -->
    <div class="flex flex-col">
      <!-- <h3 class="font-display text-2xl tracking-tight text-text-primary"> -->
      <h3
        class="font-display text-xl sm:text-2xl tracking-tight text-text-primary"
      >
        {role}
      </h3>

      <span class="text-text-secondary">
        <span class="font-sans font-bold text-text-secondary">
          {company}
        </span>
        •
        {period}
      </span>
    </div>
  </div>

  <!-- DESCRIPTION -->
  <p
    class="text-text-secondary leading-relaxed whitespace-pre-line w-full text-justify"
  >
    {description}
  </p>

  <!-- TECH -->
  {
    techs && (
      //   <div class="flex flex-wrap gap-3">
      <div class="flex flex-wrap gap-2 sm:gap-3">
        {techs.map((tech) => (
          <TechChip label={tech.label} icon={tech.icon} />
        ))}
      </div>
    )
  }
</div>
